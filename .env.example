# Example environment variables for database connection
# Copy this file to .env and fill real values (do NOT commit secrets).

# Server and database
DB_SERVER=10.121.5.80,1433
DB_DATABASE=ECU911DMS
DB_USERNAME=ereporte
DB_PASSWORD=CHANGE_ME
DB_DRIVER=ODBC Driver 18 for SQL Server

# Connection behavior
DB_TIMEOUT=30
DB_CONNECT_RETRIES=3
DB_RETRY_DELAY=2

# Encryption options (yes/no)
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERT=yes
